# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/anvikshiki

# ── Server ────────────────────────────────────────────────────────────
PORT=8080                            # API server port (defaults to 8080)
NODE_ENV=development                 # development | production

# ── Auth Secrets (generate with: openssl rand -base64 32) ─────────────
AUTH_SECRET=change_me_openssl_rand   # User session JWT secret
ADMIN_SECRET=change_me_openssl_rand  # Admin session JWT secret

# ── Admin Bootstrap ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@anvikshiki.org
ADMIN_PASSWORD_HASH=                 # bcrypt hash of admin password
                                     # Generate: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"

# ── CORS ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173   # Allowed origin for CORS
                                     # Production: https://your-domain.com

# ── File Uploads ──────────────────────────────────────────────────────
UPLOADS_DIR=/tmp/anvikshiki-uploads  # Persist uploads outside /tmp in production
API_BASE_URL=http://localhost:8080   # Used to build file download URLs

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info                       # pino log level: trace | debug | info | warn | error
