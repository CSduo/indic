    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
