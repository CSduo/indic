# ─────────────────────────────────────────────────────────────
# Ānvīkṣikī — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────
# Required for the API server and DB migrations.
# On Replit: add a PostgreSQL database via the Database tool —
#   the DATABASE_URL secret is injected automatically.
# On Vercel: add this in Project → Settings → Environment Variables.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── API Server ────────────────────────────────────────────────
# Port the API server listens on.
# Replit sets this automatically; Vercel serverless ignores it.
PORT=8080

# Runtime environment — "development" or "production"
NODE_ENV=development

# Log verbosity — "trace" | "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# ── Frontend (Vite) ───────────────────────────────────────────
# Base URL path — Replit/Vercel set this automatically.
# Leave blank (defaults to "/") unless deploying to a sub-path.
# BASE_PATH=/
