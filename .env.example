# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/anvikshiki"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="anvikshiki-media"

# Auth secrets (generate strong random strings)
AUTH_SECRET="your-auth-secret-min-32-characters-long"
ADMIN_SECRET="your-admin-secret-min-32-characters-long"

# Admin credentials (for seeding)
ADMIN_EMAIL="admin@anvikshiki.org"
ADMIN_PASSWORD_HASH=""

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (optional - for notifications)
RESEND_API_KEY=""
EMAIL_FROM="noreply@anvikshiki.org"

# Environment
NODE_ENV="development"

# Seed demo content (set to false for production)
SEED_DEMO_CONTENT="false"
