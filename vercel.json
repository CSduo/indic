{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/anvikshiki run build",
  "outputDirectory": "artifacts/anvikshiki/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets/|favicon\\.ico|robots\\.txt|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.svg|.*\\.webp|.*\\.js|.*\\.css|.*\\.woff|.*\\.woff2|.*\\.ttf).*)$",
      "destination": "/index.html"
    }
  ]
}
